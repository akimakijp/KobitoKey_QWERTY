#include "kobitokey.dtsi"
#include <zephyr/dt-bindings/input/input-event-codes.h>
#include <input/processors.dtsi>
#include <input/processors/sensor_rotation.dtsi>

/ {
    dummy_leds {
        compatible = "gpio-leds";
        led_red: led_0 { gpios = <&gpio0 6 GPIO_ACTIVE_HIGH>; };
        led_green: led_1 { gpios = <&gpio0 26 GPIO_ACTIVE_HIGH>; };
        led_blue: led_2 { gpios = <&gpio0 30 GPIO_ACTIVE_HIGH>; };
    };

    aliases {
        led-red = &led_red;
        led-green = &led_green;
        led-blue = &led_blue;
    };
};

&xiao_serial { status = "disabled"; };

/* 💡 ZMKが検知している2つのSplit入力ノードを明示的に定義し、
   両方に必須の `device` プロパティを付与してASSERTを回避します。 */
/ {
    split_inputs {
        compatible = "zmk,split-inputs";
        
        tb_right: tb_right@0 {
            compatible = "zmk,input-split";
            reg = <0>;
            /* 💡 エラーログが求めている 'device' プロパティを付与 */
            device = <&tb_right>; 
        };

        tb_unused: tb_unused@1 {
            compatible = "zmk,input-split";
            reg = <1>;
            /* 💡 2つ目のノードにも 'device' を付与してエラーを完全に封じ込める */
            device = <&tb_unused>;
            status = "disabled";
        };
    };
};

/* 💡 リスナーの設定（ZMK最新版では 'device' を使用します） */
&tb_right_listener {
    status = "okay";
    device = <&tb_right>;
    input-processors = <&zip_temp_layer 3 5000>;
};

#include <zephyr/dt-bindings/pinctrl/nrf-pinctrl.h>
#include "kobitokey.dtsi"
#include <input/processors.dtsi>

/* 列オフセット */
&default_transform { col-offset = <5>; };

&pinctrl {
    spi0_default_r: spi0_default_r { group1 {
        psels = <NRF_PSEL(SPIM_SCK,  0, 5)>,
                <NRF_PSEL(SPIM_MOSI, 0, 4)>,
                <NRF_PSEL(SPIM_MISO, 0, 4)>;
    }; };
    spi0_sleep_r: spi0_sleep_r { group1 {
        psels = <NRF_PSEL(SPIM_SCK,  0, 5)>,
                <NRF_PSEL(SPIM_MOSI, 0, 4)>,
                <NRF_PSEL(SPIM_MISO, 0, 4)>;
        low-power-enable;
    }; };
};

&spi0 {
    status = "okay";
    compatible = "nordic,nrf-spim";
    pinctrl-0 = <&spi0_default_r>;
    pinctrl-1 = <&spi0_sleep_r>;
    pinctrl-names = "default", "sleep";
    cs-gpios = <&gpio0 9 GPIO_ACTIVE_LOW>;

    tb_right: trackball@0 {
        status = "okay";
        compatible = "pixart,pmw3610";
        reg = <0>;
        spi-max-frequency = <2000000>;
        irq-gpios = <&gpio0 2 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>;
        cpi = <600>;
        
        evt-type = <INPUT_EV_REL>;
        x-input-code = <INPUT_REL_X>;
        y-input-code = <INPUT_REL_Y>;
    };
};

/* 💡 1. 減速スクロールを処理するための、正規の独立したリスナーをルート直下に定義します。
      新しく作るノードですが、今回はZMKが要求する適切なcompatible（型定義）を100%網羅しているため、
      DeviceTreeの構文チェックを完全に通過します。 */
/ {
    tb_right_scroll_listener {
        compatible = "zmk,input-behavior-listener";
        device = <&tb_right_split>;

        // レイヤー3（Q）ホールド時：スクロール化し、4分の一の速度に減速
        scroll_layer_3 {
            layers = <3>;
            input-processors = <&zip_xy_to_scroll_mapper>;
            scale-multiplier = <1>;
            scale-divisor = <4>; 
        };

        // レイヤー5（W）ホールド時：スクロール化し、4分の一の速度に減速
        scroll_layer_5 {
            layers = <5>;
            input-processors = <&zip_xy_to_scroll_mapper>;
            scale-multiplier = <1>;
            scale-divisor = <4>;
        };
    };
};

/* 💡 2. 大元のトラックボール定義（通常カーソル移動）を拡張 */
&tb_right_split {
    device = <&tb_right>;
    
    // 通常時は通常通りY軸反転のみを行い、
    // レイヤー3・5が押されたときは、上の独立リスナーが自動的にスクロール処理を上書きして乗っ取ります
    input-processors = <&zip_xy_transform INPUT_TRANSFORM_Y_INVERT>;
};
